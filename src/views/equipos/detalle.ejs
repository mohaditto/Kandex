<h1 class="mb-4"><%= equipo.nombre_equipo %></h1>
<p><%= equipo.descripcion %></p>

<h3 class="mt-4">Miembros del Equipo</h3>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Email</th>
            <th>Rol</th>
        </tr>
    </thead>
    <tbody>
        <% usuarios.forEach(usuario => { %>
            <tr>
                <td><%= usuario.nombre_usuario %></td>
                <td><%= usuario.email %></td>
                <td><%= usuario.rol %></td>
            </tr>
        <% }); %>
    </tbody>
</table>

<a href="/equipos" class="btn btn-secondary">Volver</a>