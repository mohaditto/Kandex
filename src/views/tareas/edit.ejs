<div class="overlay-edit">
    <div class="modal-edit">
        <div class="modal-header">
            <span class="modal-title">Editar tarea</span>
            <a href="/tareas" class="modal-close">✖</a>
        </div>
            <form action="/tareas/edit/<%= tarea.id %>" method="POST">
                <label class="mb-3 w-100">
                    <span class="field-label">Título</span>
                        <input type="text" class="form-control" id="titulo" name="titulo" value="<%= tarea.titulo %>" required></label>
                <label class="mb-3 w-100">
                    <span class="field-label">Descripción</span>
                        <textarea class="form-control" id="descripcion" name="descripcion" rows="4"><%= tarea.descripcion %></textarea></label>
                <label class="mb-3 w-100">
                    <span class="field-label">Estado</span>
                        <select class="form-select" id="estado" name="estado">
                            <option value="Por realizar" <%= tarea.estado === 'Por realizar' ? 'selected' : '' %>>Por realizar</option>
                            <option value="En proceso" <%= tarea.estado === 'En proceso' ? 'selected' : '' %>>En proceso</option>
                            <option value="Realizado" <%= tarea.estado === 'Realizado' ? 'selected' : '' %>>Realizado</option>
                        </select>
                </label>
                <label class="mb-3 w-100">
                    <span class="field-label">Prioridad</span>
                        <select class="form-select" id="prioridad" name="prioridad">
                            <option value="Baja" <%= tarea.prioridad === 'Baja' ? 'selected' : '' %>>Baja</option>
                            <option value="Media" <%= tarea.prioridad === 'Media' ? 'selected' : '' %>>Media</option>
                            <option value="Alta" <%= tarea.prioridad === 'Alta' ? 'selected' : '' %>>Alta</option>
                            <option value="Urgente" <%= tarea.prioridad === 'Urgente' ? 'selected' : '' %>>Urgente</option>
                        </select>
                </label>
                <label class="mb-3 w-100">
                    <span class="field-label">Fecha inicio</span>
                        <input type="date" class="form-control" id="fecha_inicio" name="fecha_inicio" value="">
                </label>
                <label class="mb-4 w-100">
                    <span class="field-label">Fecha límite</span>
                        <input type="date" class="form-control" id="fecha_limite" name="fecha_limite" value="">
                </label>
                    <div>
                        <a href="/user/board" class="btn btn-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-primary">Guardar cambios</button>
                    </div>
            </form>
    </div>
</div>