<div class="login-wrap">
  <div class="login-panel">
    <div class="login-brand">
      <div class="logo-box" style="background:linear-gradient(135deg,#059669,#10b981);box-shadow:0 12px 32px rgba(16,185,129,.4);">
        <i class="bi bi-person-plus-fill"></i>
      </div>
      <h1>Crear Cuenta</h1>
      <p>¡Únete a Kandex y organiza tu trabajo hoy!</p>
    </div>

    <div class="lcard">
      <div class="lcard-body">
        <h2>Nuevo Registro</h2>
        <p class="sub">Crea tu cuenta para empezar a usar Kandex</p>

        <%- include('../partials/flash-messages') %>

        <form action="/register" method="POST">
          <div class="fgroup">
            <label class="flabel"><i class="bi bi-person me-1"></i>Create un nombre</label>
            <input type="text" name="name" class="finput" placeholder="Tu nombre" required>
          </div>
          <div class="fgroup">
            <label class="flabel"><i class="bi bi-envelope me-1"></i>Email</label>
            <input type="email" name="email" class="finput" placeholder="tu@email.com" required>
          </div>
          <div class="fgroup">
            <label class="flabel"><i class="bi bi-key me-1"></i>Contraseña</label>
            <input type="password" name="password" class="finput" placeholder="••••••••" required>
          </div>
          <button type="submit" class="btn-login" style="background:linear-gradient(135deg,#059669,#10b981);">
            <i class="bi bi-person-check me-2"></i>Registrate
          </button>
        </form>
      </div>
      <div class="lcard-footer">
        ¿Ya tienes una cuenta? <a href="/login">Inicia Sesión</a>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
