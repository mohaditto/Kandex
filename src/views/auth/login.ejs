<div class="login-wrap">
  <div class="login-panel">
    <div class="login-brand">
      <div class="logo-box"><i class="bi bi-kanban-fill"></i></div>
      <h1>Kandex</h1>
      <p>Gestión de tareas y equipos con tablero Kanban</p>
    </div>

    <div class="demo-hint">
      <strong>Credenciales Demostrativas</strong>
      <span><b>Admin →</b> admin@kandex.com / admin123</span>
      <span><b>Usuario →</b> tv@kandex.com / user123</span>
    </div>

    <div class="lcard">
      <div class="lcard-body">
        <h2>Iniciar Sesión</h2>
        <p class="sub">Accede a tu área con tus credenciales.</p>

        <%- include('../partials/flash-messages') %>

        <form action="/login" method="POST">
          <div class="fgroup">
            <label class="flabel"><i class="bi bi-envelope me-1"></i>Email</label>
            <input type="email" name="email" class="finput" placeholder="correo@ejemplo.com" required>
          </div>
          <div class="fgroup">
            <label class="flabel"><i class="bi bi-key me-1"></i>Contraseña</label>
            <input type="password" name="password" class="finput" placeholder="••••••••" required>
          </div>
          <button type="submit" class="btn-login">
            <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesión
          </button>
        </form>
      </div>
      <div class="lcard-footer">
        ¿No tienes una cuenta? <a href="/register">Regístrate aquí</a>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
