<%- include('../partials/navbar-admin', { currentPage: 'profile' }) %>

<div class="main pt-3">
  <div class="shell admin-shell">

    <div class="sec-head">
      <h1><i class="bi bi-person-gear me-2"></i>Mi Perfil</h1>
      <span class="role-chip chip-admin" style="font-size:.7rem;padding:.22rem .7rem;">
        <i class="bi bi-shield-fill me-1"></i>Administrador
      </span>
    </div>

    <%- include('../partials/flash-messages') %>

    <div class="row g-4">
      <!-- Avatar -->
      <div class="col-12 col-md-3 d-flex flex-column align-items-center" style="padding-top:.5rem;">
        <div style="width:96px;height:96px;border-radius:50%;background:linear-gradient(135deg,var(--a),var(--a-2));display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:800;color:#fff;box-shadow:0 8px 24px rgba(245,158,11,.35);margin-bottom:1rem;">
          <%= currentUser.initials %>
        </div>
        <p style="font-size:.75rem;color:var(--muted);text-align:center;margin:0;">
          Avatar generado<br>desde tus iniciales
        </p>
      </div>

      <!-- Formulario -->
      <div class="col-12 col-md-9">
        <div class="atable" style="padding:1.5rem;">
          <h6 style="font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);margin-bottom:1.25rem;">
            <i class="bi bi-pencil-square me-1"></i>Información de la cuenta
          </h6>
          <form action="/admin/profile" method="POST">
            <div class="row g-3">
              <div class="col-12">
                <label class="flabel"><i class="bi bi-person me-1"></i>Nombre completo</label>
                <input type="text" name="name" class="finput" value="<%= currentUser.name %>" placeholder="Tu nombre completo" required>
              </div>
              <div class="col-12">
                <label class="flabel"><i class="bi bi-envelope me-1"></i>Email</label>
                <input type="email" name="email" class="finput" value="<%= currentUser.email %>" placeholder="tu@email.com" required>
              </div>
            </div>
            <hr style="border-color:#fde68a;margin:1.25rem 0;">
            <h6 style="font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);margin-bottom:1.25rem;">
              <i class="bi bi-lock me-1"></i>Cambiar contraseña
              <span style="font-weight:400;text-transform:none;letter-spacing:0;">(opcional)</span>
            </h6>
            <div class="row g-3">
              <div class="col-12 col-sm-6">
                <label class="flabel"><i class="bi bi-key me-1"></i>Nueva contraseña</label>
                <input type="password" name="password" class="finput" placeholder="••••••••">
              </div>
              <div class="col-12 col-sm-6">
                <label class="flabel"><i class="bi bi-key-fill me-1"></i>Confirmar contraseña</label>
                <input type="password" name="password2" class="finput" placeholder="••••••••">
              </div>
            </div>
            <div class="d-flex justify-content-end mt-3 gap-2">
              <a href="/admin/dashboard" class="btn btn-outline-secondary" style="border-radius:10px;font-size:.85rem;font-weight:600;">
                <i class="bi bi-x-lg me-1"></i>Cancelar
              </a>
              <button type="submit" class="btn-adm">
                <i class="bi bi-floppy me-1"></i>Guardar cambios
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

  </div>
</div>

<footer style="background:rgba(0,0,0,.3);backdrop-filter:blur(10px);border-top:1px solid rgba(255,255,255,.05);color:rgba(255,255,255,.45);font-size:.82rem;padding:.8rem;text-align:center;">
  <i class="bi bi-c-circle"></i> 2026 Kandex Administración
</footer>
