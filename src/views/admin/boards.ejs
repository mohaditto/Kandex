<%- include('../partials/navbar-admin', { currentPage: 'boards' }) %>

<style>
  .board-icon-active { color: var(--a); }
  .board-icon-archived { color: #94a3b8; }
</style>

<div class="main pt-3">
  <div class="shell admin-shell">

    <div class="sec-head">
      <h1><i class="bi bi-grid-fill me-2"></i>Gestión de Tableros</h1>
      <button class="btn-adm"><i class="bi bi-plus"></i>Crear Tablero</button>
    </div>

    <%- include('../partials/flash-messages') %>

    <!-- Filtros -->
    <form action="/admin/boards" method="GET">
      <div class="frow">
        <input type="text" name="search" class="fsearch" placeholder="Buscar tablero..."
              value="<%= filters.search %>" style="min-width:220px;">
        <select name="status" class="fsel" onchange="this.form.submit()">
          <option value="all"      <%= filters.status === 'all'      ? 'selected' : '' %>>Todos los estados</option>
          <option value="active"   <%= filters.status === 'active'   ? 'selected' : '' %>>Activo</option>
          <option value="archived" <%= filters.status === 'archived' ? 'selected' : '' %>>Archivado</option>
        </select>
        <button type="submit" class="btn-adm" style="font-size:.83rem;">
          <i class="bi bi-search"></i>Buscar
        </button>
      </div>
    </form>

    <div class="atable">
      <table>
        <thead>
          <tr>
            <th>Tablero</th>
            <th>Propietario</th>
            <th>Miembros</th>
            <th>Tareas</th>
            <th>Progreso</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% boards.forEach(b => { %>
            <tr<% if (b.status === 'archived') { %> style="opacity:.6;"<% } %>>
              <td>
                <strong>
                  <i class="bi bi-kanban me-2 <%= b.status === 'archived' ? 'board-icon-archived' : 'board-icon-active' %>"></i>
                  <%= b.name %>
                </strong>
              </td>
              <td>
                <div style="display:flex;align-items:center;">
                  <span class="uav" style="background-color:<%- b.owner_color %>;font-size:.62rem;">
                    <%= b.owner_initials %>
                  </span>
                  <%= b.owner_name %>
                </div>
              </td>
              <td><%= b.members %></td>
              <td><%= b.tasks %></td>
              <td style="min-width:130px;">
                <div style="display:flex;align-items:center;gap:.5rem;">
                  <div class="mbar" style="flex:1;">
                    <div class="mbar-fill" style="width:<%= (b.progress || 0) %>%;"></div>
                  </div>
                    <span style="font-size:.73rem;font-weight:600;color:var(--muted);white-space:nowrap;">
                    <%= (b.progress || 0) %>%
                  </span>
                </div>
              </td>
              <td>
                <% if (b.status === 'active') { %>
                  <span class="sbadge bsActive">Activo</span>
                <% } else { %>
                  <span class="sbadge bsArchived">Archivado</span>
                <% } %>
              </td>
              <td>
                <% if (b.status === 'active') { %>
                  <button class="btn btn-sm btn-outline-primary me-1" title="Ver">
                    <i class="bi bi-eye"></i>
                  </button>
                  <button class="btn btn-sm btn-outline-warning me-1" title="Editar">
                    <i class="bi bi-pencil"></i>
                  </button>
                  <button class="btn btn-sm btn-outline-danger" title="Archivar">
                    <i class="bi bi-archive"></i>
                  </button>
                <% } else { %>
                  <button class="btn btn-sm btn-outline-secondary me-1" title="Restaurar">
                    <i class="bi bi-arrow-counterclockwise"></i>
                  </button>
                  <button class="btn btn-sm btn-outline-danger" title="Eliminar">
                    <i class="bi bi-trash"></i>
                  </button>
                <% } %>
              </td>
            </tr>
          <% }) %>
          <% if (boards.length === 0) { %>
            <tr>
              <td colspan="7" style="text-align:center;color:var(--muted);padding:2rem;">
                <i class="bi bi-search me-2"></i>No se encontraron tableros con esos filtros.
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
      <small style="color:var(--muted);">
        <%= boards.length %> tableros · <%= stats.active %> activos · <%= stats.archived %> archivados
      </small>
    </div>

  </div>
</div>

<footer style="background:rgba(0,0,0,.3);backdrop-filter:blur(10px);border-top:1px solid rgba(255,255,255,.05);color:rgba(255,255,255,.45);font-size:.82rem;padding:.8rem;text-align:center;">
  <i class="bi bi-c-circle"></i> 2026 Kandex Administración
</footer>