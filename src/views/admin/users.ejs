<%- include('../partials/navbar-admin', { currentPage: 'users' }) %>

<div class="main pt-3">
  <div class="shell admin-shell">

    <div class="sec-head">
      <h1><i class="bi bi-people-fill me-2"></i>Gestión de Usuarios</h1>
      <button class="btn-adm"><i class="bi bi-person-plus"></i>Nuevo Usuario</button>
    </div>

    <%- include('../partials/flash-messages') %>

    <!-- Filtros -->
    <form action="/admin/users" method="GET">
      <div class="frow">
        <input type="text" name="search" class="fsearch" placeholder="🔍 Buscar usuario..."
              value="<%= filters.search %>" style="min-width:220px;">
        <select name="role" class="fsel" onchange="this.form.submit()">
          <option value="all"   <%= filters.role === 'all'   ? 'selected' : '' %>>Todos los roles</option>
          <option value="user"  <%= filters.role === 'user'  ? 'selected' : '' %>>Usuario</option>
          <option value="admin" <%= filters.role === 'admin' ? 'selected' : '' %>>Administrador</option>
        </select>
        <select name="status" class="fsel" onchange="this.form.submit()">
          <option value="all"      <%= filters.status === 'all'      ? 'selected' : '' %>>Todos los estados</option>
          <option value="active"   <%= filters.status === 'active'   ? 'selected' : '' %>>Activo</option>
          <option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactivo</option>
          <option value="pending"  <%= filters.status === 'pending'  ? 'selected' : '' %>>Pendiente</option>
        </select>
        <button type="submit" class="btn-adm" style="font-size:.83rem;">
          <i class="bi bi-search"></i>Buscar
        </button>
      </div>
    </form>

    <div class="atable">
      <table>
        <thead>
          <tr>
            <th>Usuario</th>
            <th>Email</th>
            <th>Rol</th>
            <th>Tableros</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
            <% const initials = u.name.split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase() %>
            <tr>
              <td>
                <div style="display:flex;align-items:center;">
                  <span class="uav" style="background:<%= u.color %>;"><%= initials %></span>
                  <strong><%= u.name %></strong>
                </div>
              </td>
              <td style="color:var(--muted);"><%= u.email %></td>
              <td>
                <% if (u.role === 'admin') { %>
                  <span class="ptag adm"><i class="bi bi-shield me-1"></i>Admin</span>
                <% } else { %>
                  <span class="ptag"><i class="bi bi-person me-1"></i>Usuario</span>
                <% } %>
              </td>
              <td><%= u.boards %></td>
              <td>
                <% if (u.status === 'active') { %>
                  <span class="sbadge sActive">Activo</span>
                <% } else if (u.status === 'inactive') { %>
                  <span class="sbadge sInactive">Inactivo</span>
                <% } else { %>
                  <span class="sbadge sPending">Pendiente</span>
                <% } %>
              </td>
              <td>
                <button class="btn btn-sm btn-outline-primary me-1" title="Editar">
                  <i class="bi bi-pencil"></i>
                </button>
                <button class="btn btn-sm btn-outline-warning me-1" title="Cambiar rol">
                  <i class="bi bi-shield"></i>
                </button>
                <button class="btn btn-sm btn-outline-danger" title="Eliminar">
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            </tr>
          <% }) %>
          <% if (users.length === 0) { %>
            <tr>
              <td colspan="6" style="text-align:center;color:var(--muted);padding:2rem;">
                <i class="bi bi-search me-2"></i>No se encontraron usuarios con esos filtros.
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
      <small style="color:var(--muted);">Mostrando <%= users.length %> de <%= totalUsers %> usuarios</small>
      <div class="d-flex gap-1">
        <button class="btn btn-sm btn-outline-secondary">‹ Anterior</button>
        <button class="btn btn-sm btn-warning" style="color:#fff;">1</button>
        <button class="btn btn-sm btn-outline-secondary">2</button>
        <button class="btn btn-sm btn-outline-secondary">3</button>
        <button class="btn btn-sm btn-outline-secondary">Siguiente ›</button>
      </div>
    </div>

  </div>
</div>

<footer style="background:rgba(0,0,0,.3);backdrop-filter:blur(10px);border-top:1px solid rgba(255,255,255,.05);color:rgba(255,255,255,.45);font-size:.82rem;padding:.8rem;text-align:center;">
  <i class="bi bi-c-circle"></i> 2026 Kandex Admin
</footer>
